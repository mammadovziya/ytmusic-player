#!/usr/bin/env node
import { spawnSync } from 'child_process';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';
import { createRequire } from 'module';

const __dirname = dirname(fileURLToPath(import.meta.url));
const require = createRequire(import.meta.url);

const PLATFORMS = {
  'darwin arm64': 'darwin-arm64',
  'darwin x64':   'darwin-x64',
  'linux x64':    'linux-x64',
  'linux arm64':  'linux-arm64',
  'win32 x64':    'win32-x64',
};

const key = `${process.platform} ${process.arch}`;
const platformDir = PLATFORMS[key];

if (!platformDir) {
  process.stderr.write(`ytmusic-player: Unsupported platform: ${process.platform} ${process.arch}\n`);
  process.exit(1);
}

const exeName = process.platform === 'win32' ? 'ytmusic-cli.exe' : 'ytmusic-cli';
const packageName = `ytmusic-player-${platformDir}`;
let binPath;

try {
  binPath = require(packageName);
} catch {
  binPath = join(__dirname, '..', 'npm', platformDir, 'bin', exeName);
}

const result = spawnSync(binPath, process.argv.slice(2), { stdio: 'inherit' });
if (result.error) {
  process.stderr.write(`ytmusic-player: Failed to launch ${packageName}. Try reinstalling with optional dependencies enabled.\n`);
  process.stderr.write(`${result.error.message}\n`);
  process.exit(1);
}

process.exit(result.status ?? 0);
