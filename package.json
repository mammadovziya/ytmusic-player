{
  "name": "ytmusic-player",
  "version": "0.3.5",
  "description": "Fast YouTube Music terminal player for Windows, macOS, and Linux, powered by mpv and yt-dlp.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/mammadovziya/ytmusic-player#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mammadovziya/ytmusic-player.git"
  },
  "bugs": {
    "url": "https://github.com/mammadovziya/ytmusic-player/issues"
  },
  "bin": {
    "ytmusic-player": "bin/ytmusic-cli",
    "ym": "bin/ytmusic-cli"
  },
  "files": [
    "bin/ytmusic-cli",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun scripts/build.ts"
  },
  "optionalDependencies": {
    "ytmusic-player-darwin-arm64": "0.3.5",
    "ytmusic-player-darwin-x64": "0.3.5",
    "ytmusic-player-linux-x64": "0.3.5",
    "ytmusic-player-linux-arm64": "0.3.5",
    "ytmusic-player-win32-x64": "0.3.5"
  },
  "keywords": [
    "youtube",
    "youtube-music",
    "youtube-music-cli",
    "youtube-player",
    "ytmusic",
    "music",
    "music-player",
    "cli",
    "command-line",
    "terminal",
    "terminal-player",
    "tui",
    "player",
    "mpv",
    "mpv-player",
    "yt-dlp",
    "yt-dlp-wrapper",
    "offline-music",
    "playlist-manager",
    "privacy",
    "private",
    "cross-platform",
    "windows",
    "macos",
    "linux",
    "bun"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "chalk": "^5.6.2",
    "typescript": "^5"
  }
}
